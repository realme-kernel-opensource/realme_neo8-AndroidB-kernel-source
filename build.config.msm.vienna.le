################################################################################
## Inheriting configs from ACK
. "${KERNEL_DIR}/build.config.constants"
ARCH=arm64
LLVM=1
CLANG_PREBUILT_BIN=prebuilts/clang/host/linux-x86/clang-${CLANG_VERSION}/bin
BUILDTOOLS_PREBUILT_BIN=build/kernel/build-tools/path/linux-x86

#################################################################################
## Target and Variant setup
MSM_ARCH=vienna_le
VARIANTS=(defconfig debug-defconfig)
[ -z "${VARIANT}" ] && VARIANT=debug-defconfig
[ -n "${VARIANT}" ] && ! [[ " ${VARIANTS[*]} " =~  ${VARIANT}  ]] && echo "Error: Invalid VARIANT specified" && exit 1


ABL_SRC=bootable/bootloader/edk2
BOOT_IMAGE_HEADER_VERSION=2
BASE_ADDRESS=0x80000000
PAGE_SIZE=4096
BUILD_BOOT_IMG=1
DTB_IMG_CREATE=1
PREFERRED_USERSPACE=le
SKIP_UNPACKING_RAMDISK=1
[ -z "${DT_OVERLAY_SUPPORT}" ] && DT_OVERLAY_SUPPORT=0

if [ "${KERNEL_CMDLINE_CONSOLE_AUTO}" != "0" ]; then
        KERNEL_CMDLINE+=' console=ttyMSM0,115200n8 earlycon=qcom_geni,0xa90000 qcom_geni_serial.con_enabled=1 loglevel=8 rootwait init=/sbin/init '
fi
KERNEL_VENDOR_CMDLINE+=' bootconfig '
